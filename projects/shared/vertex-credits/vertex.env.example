# Copy to vertex.env in your per-machine config dir (setup scripts do this for you).
# Linux/macOS: ~/.config/codemonkeys/vertex.env
# Windows:     %APPDATA%\codemonkeys\vertex.env
#
# Never commit vertex-sa.json or real secrets to git.

GOOGLE_CLOUD_PROJECT=codemonkeys-498819
GOOGLE_CLOUD_REGION=us-central1

# Optional — path to service account JSON (setup.ps1 / setup.sh can install here):
# GOOGLE_APPLICATION_CREDENTIALS=C:\Users\YOU\AppData\codemonkeys\vertex-sa.json

# Optional — Fly/production: paste JSON once, materialized to vertex-sa.json at boot:
# VERTEX_CREDENTIALS_JSON=
