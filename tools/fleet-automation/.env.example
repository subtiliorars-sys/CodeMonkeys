# Copy to .env ONLY for non-secret runtime options.
# NEVER put passwords or API keys here — use the OS credential store instead:
#   npm run dev -- credentials set itch Butler API key
#
# chmod 600 .env after creating (Unix)

# Optional: override browser profile root (default: ./user-data)
# FLEET_AUTOMATION_USER_DATA_DIR=/path/to/protected/user-data

# Optional: path to game_data.json (default: ./game_data.json)
# FLEET_AUTOMATION_DATA_FILE=./game_data.json

# Set to 1 to skip approval gates (NOT RECOMMENDED — disables anti-AI guardrail)
# FLEET_AUTOMATION_UNSAFE_SKIP_GATES=0
